# PostgreSQL — utilise le container partagé du VPS
# En Docker : host=postgres (réseau internal), pas de mdp
DB_HOST=postgres
DB_PORT=5432
DB_NAME=autotiktok
DB_USER=postgres
DB_PASSWORD=

# Scraper
MIN_VIEWS=100000
MAX_VIDEOS_PER_HASHTAG=30

# Hashtags à scraper (séparés par des virgules)
HASHTAGS=funny,fun,drole,humour,lol
